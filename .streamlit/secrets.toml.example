# Copier ce fichier vers `.streamlit/secrets.toml` (non versionné — voir `.gitignore`)
# et remplacer toutes les valeurs factices.

# --- Google Sheets ---
gsheet_id = "REMPLACE_ID_DEPUIS_URL_DU_TABLEUR"

# --- Google Cloud Storage ---
gcs_bucket_name = "nom-du-bucket-gcs"

# --- Compte de service GCP (contenu du fichier JSON téléchargé depuis la console) ---
[gcp_service_account]
type = "service_account"
project_id = "REMPLACE"
private_key_id = "REMPLACE"
private_key = """-----BEGIN PRIVATE KEY-----
REMPLACE_PAR_LA_CLE_PRIVEE_COMPLETE
-----END PRIVATE KEY-----"""
client_email = "xxx@PROJECT_ID.iam.gserviceaccount.com"
client_id = "REMPLACE"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/ENCODED_EMAIL"

# --- Connexion admin Streamlit ---
ADMIN_LOGIN = "admin"
ADMIN_PASSWORD = "mot_de_passe_fort"

# --- URL canonique de l’app (liens dans e-mails / PDF) ---
PUBLIC_APP_URL = "https://votre-app.streamlit.app"

# --- SMTP (ex. Gmail : utiliser un « mot de passe d’application ») ---
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = 587
SMTP_USER = "expediteur@example.com"
SMTP_PASSWORD = "mot_de_passe_application"
SMTP_FROM = "LumenVia <expediteur@example.com>"
SMTP_USE_TLS = true

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_FROM_NUMBER = "+33123456789"

# --- Dry-run : cibles de test si pas de ligne users dédiée ---
EMAIL_DRY_RUN_TO = "test@example.com"
SMS_DRY_RUN_TO = "+33123456789"

# Optionnel : même chose sous section (lue aussi par l’app)
# [dry_run]
# EMAIL_DRY_RUN_TO = "test@example.com"
# SMS_DRY_RUN_TO = "+33123456789"

# --- Admin e-mail : jusqu’à 3 cases « profil N » (adresses hors dépôt) ---
# EMAIL_TEST_RECIPIENT_1 : reçoit aussi une notification SMTP à chaque réponse au questionnaire « Donner votre avis ».
EMAIL_TEST_RECIPIENT_1 = "profil-test-1@example.com"
EMAIL_TEST_RECIPIENT_2 = ""
EMAIL_TEST_RECIPIENT_3 = ""

# --- IA ---
GEMINI_API_KEY = ""
OPENAI_API_KEY = ""

IA_SECRET_SAUCE_MD = """
Consignes confidentielles complémentaires (markdown).
"""

# --- API liturgique AELF (défaut si omis : https://api.aelf.org) ---
AELF_BASE_URL = "https://api.aelf.org"
